# ===============================================
# RHINE SOLUTION - Environment Variables
# ===============================================
# Copy this file to .env.local and fill in your values
# Do NOT commit .env.local to version control!

# ===============================================
# SUPABASE (Authentication & Database)
# ===============================================
# Get these from: https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-side secret (for API routes) - DO NOT prefix with NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ===============================================
# STRIPE (Payments)
# ===============================================
# Get these from: https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key
STRIPE_SECRET_KEY=sk_test_your-secret-key

# Webhook secret for local testing: stripe listen
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# ===============================================
# APPLICATION CONFIG
# ===============================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Rhine Solution
NEXT_PUBLIC_APP_DESCRIPTION=Enterprise-grade multi-service platform

# ===============================================
# CLOUDFLARE (Optional - for edge deployment)
# ===============================================
# CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
# CLOUDFLARE_ACCOUNT_ID=your-account-id

# ===============================================
# CLOUDFLARE TURNSTILE (Human Verification)
# ===============================================
# Get from: Cloudflare Dashboard → Turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key
TURNSTILE_SECRET_KEY=your-turnstile-secret-key

# ===============================================
# EMAIL (Optional - for transactional emails)
# ===============================================
# Resend API key (recommended for Next.js)
# RESEND_API_KEY=re_your-resend-key

# ===============================================
# ANALYTICS (Optional)
# ===============================================
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ===============================================
# SENTRY (Error Tracking - Optional)
# ===============================================
# Get from: https://sentry.io/settings/ -> Projects -> Your Project -> Client Keys
# NEXT_PUBLIC_SENTRY_DSN=https://xxxxx@sentry.io/xxxxx

# ===============================================
# OPENREPLAY (Session Recording - Optional)
# ===============================================
# Get from: https://openreplay.com/ -> Projects
# NEXT_PUBLIC_OPENREPLAY_KEY=your-openreplay-project-key

# ===============================================
# MEILISEARCH (Search - Optional)
# ===============================================
# Get from: https://www.meilisearch.com/ -> Cloud
# MEILISEARCH_HOST_URL=https://your-instance.meilisearch.com
# MEILISEARCH_SEARCH_KEY=your-search-key
# MEILISEARCH_ADMIN_KEY=your-admin-key

# ===============================================
# OPENAI (AI Chatbot - Optional)
# ===============================================
# Get from: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-your-openai-key
# OPENAI_ASSISTANT_ID=asst-your-assistant-id

# ===============================================
# ADMIN SETUP (Manual - Do Not Commit)
# ===============================================
# ADMIN SETUP: Set user role to 'admin' in Supabase database manually.
# See docs/sql/003-admin-role-setup.sql for instructions.
# 1. Register admin user at /register
# 2. Run SQL in Supabase SQL Editor to set role = 'admin'